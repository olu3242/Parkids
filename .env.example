# ============================================================
# PAR-KIDS — Environment Variables Reference
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or any file with real secrets
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Server-side only

# ── EXPO / MOBILE ─────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── OPENAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...           # Used in Supabase Edge Functions

# ── STRIPE ────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs
STRIPE_PRICE_FAMILY=price_...
STRIPE_PRICE_FAMILY_PRO=price_...

# ── RESEND (Email) ────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@parkids.com

# ── APP URLS ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MOBILE_SCHEME=parkids

# ── ANALYTICS ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── SENTRY ────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=...

# ── FEATURE FLAGS ─────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AI_SUMMARIES=true
NEXT_PUBLIC_ENABLE_STRIPE=false       # Set true for production
